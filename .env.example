# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────

# TCP port the API server listens on (required, must be a positive integer)
PORT=3000

# Runtime environment; controls pino-pretty transport and other env-gated behaviour
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
# Logging  (pino)
# ──────────────────────────────────────────────────────────────

# Minimum log level emitted by pino — trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────
# Database  (PostgreSQL via drizzle-orm / node-postgres)
# ──────────────────────────────────────────────────────────────

# Full PostgreSQL connection string used by the pg Pool (required)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
